{
  "manifest_version": 3,
  "name": "Aceframe",
  "description": "Capture interactive demo walkthroughs from any web page",
  "version": "1.5.1",
  "permissions": ["activeTab", "tabs", "scripting", "storage", "unlimitedStorage", "tabCapture", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*", "https://*.vercel.app/*", "https://aceframe.ai/*", "https://www.aceframe.ai/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
